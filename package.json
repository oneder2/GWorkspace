{
  "name": "gworkspace",
  "version": "3.1.0",
  "description": "Personal workspace website with Vue.js",
  "type": "module",
  "engines": {
    "node": ">=20 <21"
  },
  "scripts": {
    "dev": "vite",
    "dev:backend": "cd backend && npm run dev",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:backend\"",
    "build": "vite build",
    "preview": "vite preview",
    "migrate": "cd backend && npm run migrate",
    "generate-sitemap": "node scripts/generate-sitemap.js",
    "check:seo": "node scripts/check-public-seo.js",
    "check:cors": "node scripts/check-backend-cors.js",
    "check:backend-seo": "node scripts/check-backend-seo.js",
    "check:backend-routes": "node scripts/check-backend-routes.js",
    "check:env": "node scripts/check-env-examples.js",
    "audit:frontend": "npm audit --audit-level=moderate"
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "fuse.js": "^7.1.0",
    "highlight.js": "^11.11.1",
    "marked": "^17.0.1",
    "medium-zoom": "^1.1.0",
    "qrcode": "^1.5.4",
    "vue": "^3.4.21",
    "vue-i18n": "^9.9.1",
    "vue-router": "^4.2.5"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.7",
    "autoprefixer": "^10.4.18",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "vite": "^8.0.16",
    "vite-plugin-pwa": "^1.3.0"
  }
}
