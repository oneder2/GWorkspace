# ============================================
# 前端环境变量配置示例
# ============================================
# 复制此文件为 .env 并修改相应的配置值
# cp .env.example .env
# ============================================

# API 服务器地址。
# 开发环境默认：http://localhost:3001/api
# 生产环境当前使用：https://workspace.gellaronline.cc/api
VITE_API_URL=http://localhost:3001/api

# Spotify 正在听接口。
# 生产环境当前使用：https://workspace.gellaronline.cc/api/spotify/now-playing
# 刷新间隔单位为毫秒，60000 表示每分钟刷新一次。
VITE_SPOTIFY_NOW_PLAYING_URL=http://localhost:3001/api/spotify/now-playing
VITE_SPOTIFY_NOW_PLAYING_REFRESH_MS=60000

# Sitemap generation scripts.
# 这些变量用于 npm run generate-sitemap，不会被 Vite 自动暴露到浏览器。
SITE_URL=https://www.gellaronline.cc
SITEMAP_SOURCE=api
SITEMAP_BLOG_API_URL=https://workspace.gellaronline.cc/api/blogs?limit=500
