# ============================================
# 前端环境变量配置示例
# ============================================
# 复制此文件为 .env 并修改相应的配置值
# cp .env.example .env
# ============================================

# API 服务器地址
# 开发环境默认：http://localhost:3001/api
# 生产环境应该设置为实际的 API 地址
# 例如：https://api.yourdomain.com/api
VITE_API_URL=http://localhost:3001/api

# Spotify 正在听接口
# 默认可以直接指向当前后端的固定路由
VITE_SPOTIFY_NOW_PLAYING_URL=http://localhost:3001/api/spotify/now-playing
VITE_SPOTIFY_NOW_PLAYING_REFRESH_MS=60000
