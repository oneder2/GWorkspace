# ============================================
# Backend environment variables
# ============================================
# Copy this file to backend/.env and replace placeholder values.
# cp backend/.env.example backend/.env
# ============================================

# Runtime
NODE_ENV=production
PORT=3001

# Public canonical site URL used by dynamic SEO endpoints.
SITE_URL=https://www.gellaronline.cc
PUBLIC_SITE_URL=https://www.gellaronline.cc

# SQLite
DATABASE_PATH=database/gworkspace.db
DATABASE_BACKUP_DIR=database/backups

# Auth
# Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace_with_a_strong_random_secret
JWT_EXPIRES_IN=7d

# Cloudflare R2 object storage
R2_ACCOUNT_ID=your_r2_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=your_r2_bucket_name
R2_PUBLIC_DOMAIN=https://assets.example.com

# Optional Cloudflare cache purge integration
CF_ZONE_ID=
CF_API_TOKEN=
# Alternative names also supported:
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_API_TOKEN=

# Spotify Web API
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_REDIRECT_URI=https://workspace.gellaronline.cc/api/spotify/callback
SPOTIFY_REFRESH_TOKEN=your_spotify_refresh_token
SPOTIFY_SCOPES=user-read-currently-playing
SPOTIFY_CALLBACK_SUCCESS_URL=https://www.gellaronline.cc/

# AI provider
# Current adapter is OpenAI-compatible and defaults to DeepSeek Chat.
AI_PROVIDER=deepseek
AI_API_KEY=your_ai_api_key
AI_API_URL=https://api.deepseek.com/v1/chat/completions
AI_MODEL=deepseek-chat
AI_TIMEOUT_MS=30000
AI_SEED_IMPORT_WHITELIST=catalog:
